    "autoprefixer": "^10.4.23",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "framer-motion": "^12.29.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.563.0",
